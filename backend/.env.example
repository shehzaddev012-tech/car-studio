# Strict dealership pipeline — all required for startup

AI_PROVIDER=compositing

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

VERTEX_MIN_CONFIDENCE=0.50
PRESERVATION_MIN_GLOBAL_RETENTION=0.88
PRESERVATION_MIN_ZONE_RETENTION=0.85
PRESERVATION_MIN_SAM2_CONFIDENCE=0.62
QC_SSIM_THRESHOLD=0.82
REJECT_CROPPED_VEHICLES=false
VERTEX_REQUEST_TIMEOUT_SECONDS=60

LPIPS_ENABLED=true
QC_SSIM_THRESHOLD=0.85
QC_LPIPS_THRESHOLD=0.08
JOB_TIMEOUT_SECONDS=600

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./car_studio.db
STORAGE_BACKEND=local
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=25
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
