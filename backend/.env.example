# Copy this file to .env and fill in values.
# Note: .env files are excluded from Docker images via .dockerignore.
# In Docker, set env vars via docker-compose.yml or your orchestrator.

# App
DEBUG=false
MOCK_AI=false

# Redis (required — used as Celery broker and pub/sub)
REDIS_URL=redis://localhost:6379/0

# Database
# SQLite (local dev):
DATABASE_URL=sqlite:///./car_studio.db
# Postgres (production):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/car_studio

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=25

# S3 (only needed when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# CORS — accepts comma-separated or JSON-array format:
#   CORS_ORIGINS=http://localhost:5173,http://localhost:3000
#   CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Pipeline
QC_SSIM_THRESHOLD=0.82
JOB_TIMEOUT_SECONDS=300
